.PHONY: dev start build lint preview install

# Bắt đầu server development
dev:
	npm run dev

# Alias cho lệnh dev (chạy giống 'make dev')
start: dev

# Build source code ra production
build:
	npm run build

# Chạy linter
lint:
	npm run lint

# Xem trước bản build production ở local
preview:
	npm run preview

# Cài đặt các thư viện (dependencies)
install:
	npm install
